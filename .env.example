PORT=3333
HOST=0.0.0.0
TIMEZONE=America/Fortaleza

CHATWOOT_BASE_URL=https://chat.iainfinity.com.br
CHATWOOT_API_ACCESS_TOKEN=your_chatwoot_api_token
CHATWOOT_ACCOUNT_ID=26
CHATWOOT_INBOX_ID=186
CHATWOOT_INBOX_NAME=Atendimento Dr. Bem Estar
CHATWOOT_INBOX_PROVIDER=whatsapp
CHATWOOT_GROUP_NAME=Clinic+

BACKEND_URL=http://127.0.0.1:3333

# Postgres (snapshots do dashboard)
POSTGRES_USER=drbemestar
POSTGRES_PASSWORD=drbemestar
POSTGRES_DB=drbemestar
# Dev local conecta na porta publicada (5402). No container o compose sobrescreve para postgres:5432.
DATABASE_URL=postgres://drbemestar:drbemestar@localhost:5402/drbemestar

# Snapshots: intervalo de recomputação (ms), validade do cache (ms) e quantos guardar por período
SNAPSHOT_REFRESH_MS=300000
SNAPSHOT_TTL_MS=300000
SNAPSHOT_RETENTION=200

OPENAI_API_KEY=your_openai_api_key
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0
MAX_OUTPUT_TOKENS=350
